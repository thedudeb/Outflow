{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-macos-updater",
  "description": "Allows the main Outflow window to check, verify, install, and restart after signed macOS updates.",
  "windows": ["main"],
  "platforms": ["macOS"],
  "permissions": [
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart"
  ]
}
