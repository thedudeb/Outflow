# Full Edge Function runtime contract for local/preflight validation.
# Hosted Supabase projects inject SUPABASE_* values; do not upload reserved names as custom secrets.
# Never expose any server value through VITE_* variables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEYS={"default":"sb_publishable_your_key"}
SUPABASE_SECRET_KEYS={"default":"sb_secret_your_key"}
RESEND_API_KEY=resend-api-key-here
RESEND_WEBHOOK_SECRET=whsec_replace_with_resend_signing_secret
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replaceme
OUTFLOW_ALLOWED_ORIGINS=http://localhost:5173,https://outflow.example.com
OUTFLOW_APP_URL=https://outflow.example.com/
OUTFLOW_INVITE_FROM="Outflow <invites@outflow.example.com>"
OUTFLOW_REMINDER_FROM="Outflow <reminders@outflow.example.com>"
OUTFLOW_CRON_SECRET=replace-with-at-least-32-random-characters
OUTFLOW_OPERATIONS_SECRET=replace-with-a-different-32-character-random-secret
OUTFLOW_DEPLOYMENT_COMMIT=replace-with-the-exact-40-character-git-commit
