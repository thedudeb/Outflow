{
  "name": "outflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test:account-prompts": "node --test tests/account-prompt.test.js",
    "test:feature-access": "node --test tests/feature-access.test.js",
    "test:service-readiness": "node --test tests/service-readiness.test.js",
    "test:function-types": "deno check --frozen --lock=deno.lock --node-modules-dir=auto supabase/functions/delete-account/index.ts supabase/functions/send-ledger-invite/index.ts supabase/functions/create-pro-checkout/index.ts supabase/functions/stripe-webhook/index.ts supabase/functions/send-due-reminders/index.ts supabase/functions/calendar-feed/index.ts",
    "test:account-foundation": "sh scripts/test-account-foundation.sh",
    "test:account-service": "playwright test --config=playwright.account.config.js",
    "test:pwa-cache": "node --test tests/pwa-cache.test.js",
    "pretest:pwa": "npm run build",
    "test:pwa": "playwright test --config=playwright.pwa.config.js",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.75.0",
    "ics": "^3.12.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.4.3"
  }
}
